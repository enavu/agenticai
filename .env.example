# ─── Home Assistant ───────────────────────────────────────────────────────────
# URL to your HA instance (no trailing slash, no port if using standard 80/443)
HA_URL=https://hotel89408.com
# Long-lived token: HA → Profile (bottom-left) → Long-Lived Access Tokens → Create Token
HA_TOKEN=

# ─── Anthropic ────────────────────────────────────────────────────────────────
# console.anthropic.com → API Keys → Create Key (requires $5 credit to activate)
ANTHROPIC_API_KEY=

# ─── Cyclebar ─────────────────────────────────────────────────────────────────
CYCLEBAR_USERNAME=
CYCLEBAR_PASSWORD=

# ─── Instagram (optional — leave blank to skip) ───────────────────────────────
# Meta Developer Portal → Instagram Graph API (free, needs Business/Creator acct)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Any long random string — signs internal session tokens
JWT_SECRET=change-this-to-a-long-random-string
# Your login credentials for the private chat/control interface
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=your-password-here
