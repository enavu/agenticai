enavu.io {
    tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key

    # WebSocket upgrade for chat
    handle /ws/* {
        reverse_proxy api:8080
    }

    # API routes (v1 only — /api/auth/* is a Next.js route handler)
    handle /api/v1/* {
        reverse_proxy api:8080
    }

    handle /health {
        reverse_proxy api:8080
    }

    # Trip Fund Coach — strip /trips prefix before proxying
    handle /trips* {
        uri strip_prefix /trips
        reverse_proxy tfc:3001
    }

    # Everything else → Next.js frontend
    handle {
        reverse_proxy frontend:3000
    }
}
